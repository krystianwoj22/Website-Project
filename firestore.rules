rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function isSignedIn() { 
      return request.auth != null && request.auth.token.email_verified == true; 
    }
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Phase 4: Match Blocks

    // User Profile
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
                     && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin']);
      
      function isValidUser(data) {
        return data.userId == request.auth.uid
          && data.email is string && data.email.size() <= 256
          && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
          && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 512));
      }
    }

    // Video Ideas
    match /video_ideas/{ideaId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidIdea(incoming()) && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
      
      function isValidIdea(data) {
        return data.userId == request.auth.uid
          && data.title is string && data.title.size() <= 200
          && data.thumbnailConcept is string && data.thumbnailConcept.size() <= 1000
          && data.viewPotential is string && data.viewPotential.size() <= 50
          && data.whyItWorks is string && data.whyItWorks.size() <= 1000
          && data.audience in ['Beginner', 'Intermediate', 'Advanced']
          && data.createdAt == request.time;
      }
    }
  }
}
