rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Gallery Image Validation
    function isValidGalleryImage(data) {
      return data.keys().hasAll(['url', 'prompt', 'userId', 'createdAt']) &&
             data.keys().size() <= 6 &&
             data.url is string && data.url.size() < 2000000 && // Large for base64 if needed, but pref URLs
             data.prompt is string && data.prompt.size() <= 2000 &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    match /gallery/{imageId} {
      // Anyone signed in can read the gallery
      allow list: if isSignedIn();
      allow get: if isSignedIn();

      // Only signed in users can create/delete their own images
      allow create: if isSignedIn() && isValidGalleryImage(request.resource.data);
      allow update: if false; // Images are immutable in this app
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
