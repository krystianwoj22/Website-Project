{
  "entities": {
    "GalleryImage": {
      "title": "Gallery Image",
      "description": "An image generated by the AI and saved to the gallery.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "prompt": { "type": "string" },
        "style": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url", "prompt", "userId", "createdAt"]
    }
  },
  "firestore": {
    "gallery": {
      "schema": "GalleryImage",
      "description": "A collection of images generated by users."
    }
  }
}
