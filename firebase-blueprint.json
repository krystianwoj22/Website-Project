{
  "entities": {
    "VideoIdea": {
      "title": "VideoIdea",
      "description": "A generated YouTube video idea for Claude AI educators.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The video title." },
        "thumbnailConcept": { "type": "string", "description": "Description of the thumbnail." },
        "viewPotential": { "type": "string", "description": "Estimated view count range." },
        "whyItWorks": { "type": "string", "description": "Logic behind the trends." },
        "audience": { "type": "string", "enum": ["Beginner", "Intermediate", "Advanced"] },
        "userId": { "type": "string", "description": "The owner of this idea." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "thumbnailConcept", "userId", "createdAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User preferences and metadata.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Basic user profile data."
    },
    "/video_ideas/{ideaId}": {
      "schema": "VideoIdea",
      "description": "Collection of ideas generated by users."
    }
  }
}
